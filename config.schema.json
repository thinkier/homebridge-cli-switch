{
  "pluginAlias": "SwitchToShell",
  "pluginType": "accessory",
  "schema": {
    "name": {
      "title": "Name",
      "type": "string",
      "placeholder": "Name"
    },
    "shell": {
      "title": "Shell Interpreter",
      "type": "string",
      "required": true,
      "default": "bash"
    },
    "latch": {
      "title": "Latch",
      "type": "boolean",
      "default": false,
      "required": true
    },
    "timeout": {
      "title": "Timeout (ms)",
      "type": "number",
      "default": 1000,
      "required": true
    },
    "onCommand": {
      "title": "On Command",
      "type": "number",
      "placeholder": "curl https://one.one.one.one/",
      "required": true
    },
    "offCommand": {
      "title": "Off Command",
      "type": "number",
      "placeholder": "sudo poweroff",
      "required": false,
      "condition": {
        "functionBody": "return model.latch === true;"
      }
    }
  }
}
